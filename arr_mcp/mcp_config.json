{
  "mcpServers": {
    "arr-mcp": {
      "command": "uv",
      "args": [
        "run",
        "arr-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "SONARRTOOL": "True",
        "RADARRTOOL": "True",
        "LIDARRTOOL": "True",
        "PROWLARRTOOL": "True",
        "BAZARRTOOL": "True",
        "SEERRTOOL": "True",
        "CHAPTARRTOOL": "True"
      }
    }
  }
}
